# ============================================
# Tulie Workforce — Environment Variables
# ============================================
# IMPORTANT: This app shares the SAME Supabase project as Tulie CRM.
# Copy the SUPABASE_URL, ANON_KEY, and SERVICE_ROLE_KEY from your CRM .env

# --- Supabase (SAME as CRM) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# --- OpenAI (for AI Agents) ---
OPENAI_API_KEY=sk-...

# --- n8n ---
N8N_BASE_URL=https://n8n.tulie.app
N8N_WEBHOOK_SECRET=your_super_secret_for_webhook
# N8N Postgres Settings (For Supabase/VPS DB)
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
DB_POSTGRESDB_HOST=your_supabase_project_ref.supabase.co
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your_supabase_db_password

# --- Facebook Ads & Auto Poster ---
FB_APP_ID=
FB_APP_SECRET=
FB_ACCESS_TOKEN=your_facebook_page_or_user_access_token
FB_PAGE_ID=your_facebook_page_id
FB_AD_ACCOUNT_ID=act_your_ad_account_id

# --- Content Automation / All In One ---
GOOGLE_SHEET_ID=your_google_sheet_id
WP_URL=https://your_wordpress_site.com
SLACK_REVIEW_CHANNEL=your_slack_channel_id
BRAND_NAME=Tulie
LOGO_URL=https://your_logo_url.com
