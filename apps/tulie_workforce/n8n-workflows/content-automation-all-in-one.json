      "position": [1140, -400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.bannerbear.com/v2/images/{{ $json.uid }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "bannerbear-poll",
      "name": "Check Image Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1360, -400],
