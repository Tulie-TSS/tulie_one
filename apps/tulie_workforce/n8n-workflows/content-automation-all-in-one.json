      "name": "Set Image URL",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1800, -400]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.channel }}", "rightValue": "facebook", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": "Facebook" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.channel }}", "rightValue": "website", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": "Website" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.channel }}", "rightValue": "both", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": "Both" }
          ]
        }
      },
      "id": "switch-channel",
      "name": "🔀 Route by Channel",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [2020, -400]
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "model": { "__rl": true, "mode": "list", "value": "gpt-4o" },
        "messages": { "values": [{ "content": "=Bạn là content creator chuyên nghiệp cho thương hiệu {{ $env.BRAND_NAME }}.\n\n**CHỦ ĐỀ:** {{ $json.topic }}\n**TỪ KHOÁ:** {{ $json.keywords }}\n**THÔNG TIN CỐT LÕI:** {{ $json.core_message }}\n**TONE:** {{ $json.tone }}\n\nViết caption Facebook:\n- Hook gây tò mò (1-2 câu)\n- Nội dung chính truyền tải thông tin cốt lõi\n- CTA: {{ $json.cta_text }}\n- 5-8 hashtag (mix phổ biến + niche)\n- 150-300 từ, có emoji phù hợp\n- Tiếng Việt, tone: {{ $json.tone }}\n\nChỉ trả về caption." }] },
        "options": { "temperature": 0.7, "maxTokens": 1000 }
      },
      "id": "ai-fb",
      "name": "✍️ AI: Facebook Caption",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.8,
      "position": [2280, -550],
      "credentials": { "openAiApi": { "id": "OPENAI_CREDENTIAL_ID", "name": "OpenAI" } }
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "model": { "__rl": true, "mode": "list", "value": "gpt-4o" },
        "messages": { "values": [{ "content": "=Bạn là SEO content writer cho {{ $env.BRAND_NAME }}.\n\n**CHỦ ĐỀ:** {{ $json.topic }}\n**TỪ KHOÁ:** {{ $json.keywords }}\n**THÔNG TIN CỐT LÕI:** {{ $json.core_message }}\n\nViết bài blog SEO tiếng Việt:\n- H1 chứa từ khoá chính\n- Meta description ≤155 ký tự\n- Cấu trúc: Intro → 3-5 H2 → Conclusion\n- 800-1200 từ, không nhồi keyword\n- CTA cuối: {{ $json.cta_text }}\n\nOutput:\n---\ntitle: \"...\"\nmeta_description: \"...\"\n---\n[Nội dung]" }] },
        "options": { "temperature": 0.7, "maxTokens": 3000 }
      },
      "id": "ai-wp",
      "name": "✍️ AI: Website Article",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.8,
      "position": [2280, -250],
      "credentials": { "openAiApi": { "id": "OPENAI_CREDENTIAL_ID", "name": "OpenAI" } }
    },
    {
      "parameters": {
        "mode": "combine",
        "mergeByFields": { "values": [{ "field1": "post_id", "field2": "post_id" }] },
        "options": {}
      },
      "id": "merge-ai",
      "name": "Merge AI Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [2520, -400]
