{
  "name": "Content Automation Pipeline (All-in-One)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "minutes", "minutesInterval": 30 }]
        }
      },
      "id": "trigger-generation",
      "name": "⏰ Check New Content (30min)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, -400],
      "notes": "FLOW 1: Content Generation — chạy mỗi 30 phút"
    },
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "minutes", "minutesInterval": 5 }]
        }
      },
      "id": "trigger-publish",
      "name": "⏰ Check Publish Queue (5min)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 600],
      "notes": "FLOW 3: Scheduled Publisher — chạy mỗi 5 phút"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "content-approval",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "trigger-approval",
      "name": "🔔 Webhook: Slack Approval",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 100],
      "webhookId": "content-approval-webhook",
      "notes": "FLOW 2: Approval Handler — nhận callback từ Slack"
    },

    {
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.GOOGLE_SHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "ContentPlan" },
        "filtersUI": { "values": [{ "lookupColumn": "status", "lookupValue": "pending" }] },
        "options": {}
      },
      "id": "read-pending",
      "name": "📊 Read Pending Content",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [260, -400],
      "credentials": { "googleSheetsOAuth2Api": { "id": "GOOGLE_SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [{ "leftValue": "={{ $json.status }}", "rightValue": "pending", "operator": { "type": "string", "operation": "equals" } }]
        }
      },
      "id": "filter-pending",
      "name": "Filter Pending",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [480, -400]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.GOOGLE_SHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "ContentPlan" },
        "columns": { "mappingMode": "defineBelow", "value": { "status": "creating" }, "matchingColumns": ["post_id"] }
      },
      "id": "set-creating",
      "name": "Status → Creating",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [700, -400],
      "credentials": { "googleSheetsOAuth2Api": { "id": "GOOGLE_SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.bannerbear.com/v2/images",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"template\": \"{{ $json.image_template }}\",\n  \"modifications\": [\n    { \"name\": \"background\", \"image_url\": \"{{ $json.background_url }}\" },\n    { \"name\": \"person\", \"image_url\": \"{{ $json.person_image_url }}\" },\n    { \"name\": \"logo\", \"image_url\": \"{{ $env.LOGO_URL }}\" },\n    { \"name\": \"headline\", \"text\": \"{{ $json.headline_text }}\" },\n    { \"name\": \"subtext\", \"text\": \"{{ $json.sub_text }}\" },\n    { \"name\": \"cta\", \"text\": \"{{ $json.cta_text }}\" }\n  ]\n}",
        "options": {}
      },
      "id": "bannerbear-create",
      "name": "🖼️ Create Image (Bannerbear)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, -400],
      "credentials": { "httpHeaderAuth": { "id": "BANNERBEAR_CREDENTIAL_ID", "name": "Bannerbear API" } }
