    {
      "parameters": {
        "operation": "update",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.GOOGLE_SHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "ContentPlan" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "generated_image_url": "={{ $json.generated_image_url }}",
            "generated_caption_fb": "={{ $json.generated_caption_fb || '' }}",
            "generated_article_wp": "={{ $json.generated_article_wp || '' }}",
            "status": "review"
          },
          "matchingColumns": ["post_id"]
        }
      },
      "id": "save-content",
      "name": "💾 Save to Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [2740, -400],
      "credentials": { "googleSheetsOAuth2Api": { "id": "GOOGLE_SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "channel": "={{ $env.SLACK_REVIEW_CHANNEL }}",
        "text": "📋 Content Review",
        "blocksUi": {
          "blocksValues": [
            { "type": "header", "text": { "type": "plain_text", "text": "📋 Content Review #{{ $json.post_id }}" } },
            { "type": "section", "text": { "type": "mrkdwn", "text": "*Channel:* {{ $json.channel }} | *Topic:* {{ $json.topic }}\n*Scheduled:* {{ $json.date_planned }} {{ $json.time_planned }}" } },
            { "type": "image", "title": { "type": "plain_text", "text": "Generated Image" }, "image_url": "={{ $json.generated_image_url }}", "alt_text": "content image" },
            { "type": "section", "text": { "type": "mrkdwn", "text": "*📱 Facebook Caption:*\n>>> {{ $json.generated_caption_fb }}" } },
            { "type": "divider" },
            { "type": "actions", "block_id": "review_{{ $json.post_id }}", "elements": [
              { "type": "button", "text": { "type": "plain_text", "text": "✅ Approve" }, "style": "primary", "action_id": "approve_content", "value": "{{ $json.post_id }}" },
              { "type": "button", "text": { "type": "plain_text", "text": "❌ Reject" }, "style": "danger", "action_id": "reject_content", "value": "{{ $json.post_id }}" },
              { "type": "button", "text": { "type": "plain_text", "text": "✏️ Edit" }, "action_id": "edit_content", "value": "{{ $json.post_id }}" }
            ]}
          ]
        }
      },
      "id": "slack-review",
      "name": "📤 Send for Review",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [2960, -400],
      "credentials": { "slackApi": { "id": "SLACK_CREDENTIAL_ID", "name": "Slack Bot" } }
    },

    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "OK",
        "options": {}
      },
      "id": "webhook-response",
      "name": "Respond 200 OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [260, 200]
    },
    {
      "parameters": {
        "jsCode": "const payload = JSON.parse($input.first().json.body.payload);\nconst action = payload.actions[0];\nreturn [{ json: {\n  post_id: action.value,\n  action: action.action_id,\n  reviewer: payload.user.username,\n  reviewer_id: payload.user.id,\n  response_url: payload.response_url,\n  timestamp: new Date().toISOString()\n}}];"
      },
      "id": "parse-slack",
      "name": "Parse Slack Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 0]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "approve_content", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": "Approve" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "reject_content", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": "Reject" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "edit_content", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": "Edit" }
          ]
        }
      },
      "id": "switch-action",
      "name": "🔀 Route Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [480, 0]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.GOOGLE_SHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "ContentPlan" },
        "columns": { "mappingMode": "defineBelow", "value": { "status": "approved", "approval_note": "=Approved by {{ $json.reviewer }} at {{ $json.timestamp }}" }, "matchingColumns": ["post_id"] }
      },
      "id": "approve-sheet",
      "name": "✅ Status → Approved",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [740, -100],
      "credentials": { "googleSheetsOAuth2Api": { "id": "GOOGLE_SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.response_url }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"replace_original\": true, \"text\": \"✅ *Content #{{ $json.post_id }} APPROVED* by <@{{ $json.reviewer_id }}>\" }"
      },
      "id": "slack-approved",
      "name": "Slack: Confirmed ✅",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [980, -100]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.GOOGLE_SHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "ContentPlan" },
        "columns": { "mappingMode": "defineBelow", "value": { "status": "rejected", "approval_note": "=Rejected by {{ $json.reviewer }} at {{ $json.timestamp }}" }, "matchingColumns": ["post_id"] }
      },
      "id": "reject-sheet",
      "name": "❌ Status → Rejected",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [740, 50],
      "credentials": { "googleSheetsOAuth2Api": { "id": "GOOGLE_SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.response_url }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"replace_original\": true, \"text\": \"❌ *Content #{{ $json.post_id }} REJECTED* by <@{{ $json.reviewer_id }}>. Set status to 'pending' to retry.\" }"
      },
      "id": "slack-rejected",
      "name": "Slack: Confirmed ❌",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [980, 50]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.response_url }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"replace_original\": false, \"text\": \"✏️ Edit requested for #{{ $json.post_id }}. Update Sheet + set status to 'pending' to regenerate.\" }"
      },
      "id": "slack-edit",
      "name": "Slack: Edit Requested ✏️",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 200]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.GOOGLE_SHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "ContentPlan" },
        "columns": { "mappingMode": "defineBelow", "value": { "status": "editing", "approval_note": "=Edit requested by {{ $json.reviewer }}" }, "matchingColumns": ["post_id"] }
      },
      "id": "edit-sheet",
      "name": "Status → Editing",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [980, 200],
      "credentials": { "googleSheetsOAuth2Api": { "id": "GOOGLE_SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },

    {
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $env.GOOGLE_SHEET_ID }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "ContentPlan" },
        "filtersUI": { "values": [{ "lookupColumn": "status", "lookupValue": "approved" }] },
        "options": {}
      },
      "id": "read-approved",
      "name": "📊 Get Approved Posts",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [260, 600],
      "credentials": { "googleSheetsOAuth2Api": { "id": "GOOGLE_SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst items = $input.all();\nconst ready = [];\nfor (const item of items) {\n  const d = item.json.date_planned;\n  const t = item.json.time_planned;\n  if (!d || !t) continue;\n  const scheduled = new Date(`${d}T${t}:00+07:00`);\n  if (scheduled <= now) ready.push({ json: { ...item.json, scheduled_time: scheduled.toISOString() } });\n}\nreturn ready.length ? ready : [];"
      },
      "id": "filter-time",
      "name": "⏰ Filter: Time to Publish",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 600]
    },
    {
      "parameters": {
        "conditions": {
          "combinator": "or",
          "conditions": [
            { "leftValue": "={{ $json.channel }}", "rightValue": "facebook", "operator": { "type": "string", "operation": "equals" } },
            { "leftValue": "={{ $json.channel }}", "rightValue": "both", "operator": { "type": "string", "operation": "equals" } }
          ]
        }
      },
      "id": "if-fb",
      "name": "Post to FB?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [740, 500]
    },
    {
      "parameters": {
        "conditions": {
          "combinator": "or",
          "conditions": [
            { "leftValue": "={{ $json.channel }}", "rightValue": "website", "operator": { "type": "string", "operation": "equals" } },
            { "leftValue": "={{ $json.channel }}", "rightValue": "both", "operator": { "type": "string", "operation": "equals" } }
          ]
        }
      },
      "id": "if-wp",
      "name": "Post to WP?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [740, 700]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $env.FB_PAGE_ID }}/photos",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"url\": \"{{ $json.generated_image_url }}\",\n  \"caption\": {{ JSON.stringify($json.generated_caption_fb) }},\n  \"published\": true\n}",
        "sendQuery": true,
        "queryParameters": { "parameters": [{ "name": "access_token", "value": "={{ $env.FB_ACCESS_TOKEN }}" }] },
        "options": {}
      },
      "id": "publish-fb",
      "name": "📱 Publish Facebook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [980, 500]
    },
    {
      "parameters": {
        "jsCode": "const article = $json.generated_article_wp || '';\nlet title = '', meta = '', content = article;\nconst fm = article.match(/^---\\n([\\s\\S]*?)\\n---\\n([\\s\\S]*)$/);\nif (fm) {\n  const y = fm[1]; content = fm[2].trim();\n  const t = y.match(/title:\\s*[\"'](.+?)[\"']/); if (t) title = t[1];\n  const m = y.match(/meta_description:\\s*[\"'](.+?)[\"']/); if (m) meta = m[1];\n}\ncontent = content.replace(/^### (.+)$/gm,'<h3>$1</h3>').replace(/^## (.+)$/gm,'<h2>$1</h2>').replace(/^# (.+)$/gm,'<h1>$1</h1>').replace(/\\*\\*(.+?)\\*\\*/g,'<strong>$1</strong>').replace(/\\*(.+?)\\*/g,'<em>$1</em>').replace(/\\n\\n/g,'</p><p>');\nreturn [{ json: { ...$json, wp_title: title || $json.topic, wp_meta: meta, wp_content: content } }];"
      },
      "id": "parse-wp",
      "name": "Parse Article → HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [980, 700]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WP_URL }}/wp-json/wp/v2/media",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Content-Disposition", "value": "=attachment; filename=\"post-{{ $json.post_id }}.jpg\"" }] },
        "sendBody": true,
        "contentType": "raw",
        "body": "={{ $json.generated_image_url }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "options": {}
      },
      "id": "wp-media",
      "name": "WP: Upload Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1220, 700],
      "credentials": { "httpBasicAuth": { "id": "WP_CREDENTIAL_ID", "name": "WordPress" } }
