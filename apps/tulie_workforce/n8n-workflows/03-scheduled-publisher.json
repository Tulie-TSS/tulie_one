        "genericAuthType": "httpBasicAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"title\": {{ JSON.stringify($('Parse Article for WordPress').item.json.wp_title) }},\n  \"content\": {{ JSON.stringify($('Parse Article for WordPress').item.json.wp_content) }},\n  \"status\": \"publish\",\n  \"featured_media\": {{ $json.id }},\n  \"meta\": {\n    \"_yoast_wpseo_metadesc\": {{ JSON.stringify($('Parse Article for WordPress').item.json.wp_meta_description) }}\n  }\n}",
        "options": {}
      },
      "id": "wp-create-post",
      "name": "WP: Create Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1360, 0],
      "credentials": {
        "httpBasicAuth": {
