{
  "name": "Scheduled Publisher",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 5
            }
          ]
        }
      },
      "id": "schedule-publish",
      "name": "Check Every 5min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0],
      "notes": "Kiểm tra bài đã approved và đến giờ đăng mỗi 5 phút"
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $env.GOOGLE_SHEET_ID }}"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "ContentPlan"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "status",
              "lookupValue": "approved"
            }
          ]
        },
        "options": {}
      },
      "id": "read-approved",
      "name": "Get Approved Posts",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [220, 0],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Filter posts where scheduled time <= now\nconst now = new Date();\nconst items = $input.all();\nconst readyItems = [];\n\nfor (const item of items) {\n  const datePlanned = item.json.date_planned; // YYYY-MM-DD\n  const timePlanned = item.json.time_planned;  // HH:mm\n  \n  if (!datePlanned || !timePlanned) continue;\n  \n  const scheduledTime = new Date(`${datePlanned}T${timePlanned}:00+07:00`);\n  \n  if (scheduledTime <= now) {\n    readyItems.push({\n      json: {\n        ...item.json,\n        scheduled_time: scheduledTime.toISOString(),\n        is_past_due: true\n      }\n    });\n  }\n}\n\nif (readyItems.length === 0) {\n  // Return empty to stop execution\n  return [];\n}\n\nreturn readyItems;"
      },
      "id": "filter-ready",
      "name": "Filter: Time to Publish",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 0],
      "notes": "Chỉ lấy các bài có date_planned + time_planned <= now"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "or",
          "conditions": [
            {
              "leftValue": "={{ $json.channel }}",
              "rightValue": "facebook",
              "operator": { "type": "string", "operation": "equals" }
            },
            {
              "leftValue": "={{ $json.channel }}",
              "rightValue": "both",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "if-facebook",
      "name": "Post to Facebook?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [660, -100]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "or",
          "conditions": [
            {
              "leftValue": "={{ $json.channel }}",
              "rightValue": "website",
              "operator": { "type": "string", "operation": "equals" }
            },
            {
              "leftValue": "={{ $json.channel }}",
              "rightValue": "both",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "if-website",
      "name": "Post to Website?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [660, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $env.FB_PAGE_ID }}/photos",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"url\": \"{{ $json.generated_image_url }}\",\n  \"caption\": {{ JSON.stringify($json.generated_caption_fb) }},\n  \"published\": true\n}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $env.FB_ACCESS_TOKEN }}"
            }
          ]
        },
        "options": {}
      },
      "id": "publish-facebook",
      "name": "Publish to Facebook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, -200],
      "notes": "Post ảnh + caption lên Facebook Page\nDùng Page Access Token (long-lived)"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "fb-url",
              "name": "fb_post_url",
              "value": "=https://facebook.com/{{ $json.post_id }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "set-fb-url",
      "name": "Set FB Post URL",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1140, -200]
    },
    {
      "parameters": {
        "jsCode": "// Parse the article to extract title and meta_description\nconst article = $json.generated_article_wp;\nlet title = '';\nlet metaDescription = '';\nlet content = article;\n\n// Extract YAML frontmatter\nconst frontmatterMatch = article.match(/^---\\n([\\s\\S]*?)\\n---\\n([\\s\\S]*)$/);\nif (frontmatterMatch) {\n  const frontmatter = frontmatterMatch[1];\n  content = frontmatterMatch[2].trim();\n  \n  const titleMatch = frontmatter.match(/title:\\s*[\"'](.+?)[\"']/);\n  if (titleMatch) title = titleMatch[1];\n  \n  const metaMatch = frontmatter.match(/meta_description:\\s*[\"'](.+?)[\"']/);\n  if (metaMatch) metaDescription = metaMatch[1];\n}\n\n// Convert markdown headings to HTML\ncontent = content\n  .replace(/^### (.+)$/gm, '<h3>$1</h3>')\n  .replace(/^## (.+)$/gm, '<h2>$1</h2>')\n  .replace(/^# (.+)$/gm, '<h1>$1</h1>')\n  .replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>')\n  .replace(/\\*(.+?)\\*/g, '<em>$1</em>')\n  .replace(/\\n\\n/g, '</p><p>')\n  .replace(/^(.+)$/gm, (match) => {\n    if (match.startsWith('<')) return match;\n    return `<p>${match}</p>`;\n  });\n\nreturn [{\n  json: {\n    ...$json,\n    wp_title: title || $json.topic,\n    wp_meta_description: metaDescription,\n    wp_content: content\n  }\n}];"
      },
      "id": "parse-article",
      "name": "Parse Article for WordPress",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 0],
      "notes": "Extract title, meta_description từ YAML frontmatter\nConvert markdown → HTML cho WordPress"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WP_URL }}/wp-json/wp/v2/media",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Disposition",
              "value": "=attachment; filename=\"post-{{ $json.post_id }}.jpg\""
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "body": "={{ $json.generated_image_url }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "options": {
          "redirect": {
            "redirect": {
              "followRedirects": true
            }
          }
        }
      },
      "id": "wp-upload-image",
      "name": "WP: Upload Featured Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1140, 0],
      "credentials": {
        "httpBasicAuth": {
          "id": "WP_CREDENTIAL_ID",
          "name": "WordPress Basic Auth"
