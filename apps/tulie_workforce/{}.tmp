// ─── Types ───────────────────────────────────────────────

type WorkflowStatus = "active" | "inactive" | "error";

interface WorkflowExec {
    id: string;
    status: "success" | "error" | "running";
    startedAt: string;
    duration: string;
}

interface N8nWorkflow {
    id: string;
    name: string;
    description: string;
    status: WorkflowStatus;
    trigger: string;
    triggerIcon: typeof Zap;
    nodes: string[];
    lastRun?: string;
    totalRuns: number;
    successRate: number;
    recentExecutions: WorkflowExec[];
    tags: string[];
}

